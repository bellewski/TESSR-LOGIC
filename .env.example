# TESSR-LOGIC Environment Configuration
# Copy this file to .env and adjust values as needed.
# The app works without a .env — these are all optional overrides.

# ── Ollama ──────────────────────────────────────────────────────────────────
# Base URL of your local Ollama instance
OLLAMA_BASE_URL=http://localhost:11434

# Model used for fast/draft builds (lower quality, faster)
OLLAMA_FAST_MODEL=llama3.2:3b

# Model used for quality builds (higher quality, slower)
# Default fits 6GB+ VRAM GPUs. If you have 10GB+ VRAM, consider
# qwen2.5-coder:14b or deepseek-coder:33b for better output.
OLLAMA_QUALITY_MODEL=qwen2.5-coder:7b

# Request timeout in seconds (architect phase needs time for large prompts)
OLLAMA_TIMEOUT=300

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite database file path (relative to project root)
DATABASE_URL=sqlite:///./tessr_logic.db

# ── Workspace ────────────────────────────────────────────────────────────────
# Default workspace directory for build artifacts.
# By default this is relative to where you run start.bat (./workspace/builds).
# Change this to any absolute path to store builds elsewhere, e.g.:
# WORKSPACE_PATH=C:\BuildOutput
WORKSPACE_PATH=./workspace/builds

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=TESSR-LOGIC
DEBUG=false
